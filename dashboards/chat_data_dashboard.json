          "format": "table",
          "rawSql": "SELECT\n  u.username,\n  m.content,\n  m.created_at\nFROM messages AS m\nJOIN conversations AS c ON m.conversation_id = c.id\nJOIN users AS u ON c.user_id = u.id\nWHERE m.role = 'user' AND $__timeFilter(m.created_at)\nORDER BY m.created_at DESC\nLIMIT 20",
